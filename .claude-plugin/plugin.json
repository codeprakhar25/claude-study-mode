{
  "name": "study-mode",
  "version": "0.1.2",
  "description": "Strict tutor mode. Turns Claude into a teacher that paces one concept at a time, verifies understanding, gathers resources, reviews YOUR code, and hard-blocks itself from writing code for you.",
  "author": {
    "name": "Prakhar Khatri"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/study-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading study mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/study-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking study mode..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/study-guard.js\"",
            "timeout": 5,
            "statusMessage": "Study guard..."
          }
        ]
      }
    ]
  }
}
